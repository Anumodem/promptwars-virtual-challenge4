{
  "name": "matchday-copilot",
  "version": "1.2.0",
  "description": "GenAI-enabled stadium operations & fan experience platform for FIFA World Cup 2026",
  "private": true,
  "type": "module",
  "scripts": {
    "install:all": "npm install && npm install --prefix client",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "start": "NODE_ENV=production node server/index.js",
    "test": "npm run lint && npm run test:server && npm run test:client",
    "test:server": "node --test server/test/*.test.js",
    "test:client": "npm test --prefix client",
    "lint": "eslint ."
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "supertest": "^7.0.0",
    "eslint": "^9.11.0",
    "@eslint/js": "^9.11.0",
    "eslint-plugin-react": "^7.36.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.9.0"
  },
  "license": "MIT"
}